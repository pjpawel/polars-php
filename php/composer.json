{
  "name": "pjpawel/polars-tests",
  "description": "Tests for Polars PHP bindings",
  "version": "0.5.0",
  "authors": [
    {
      "name": "pjpawel",
      "email": "pawel.jan.podgorski@gmail.com"
    }
  ],
  "minimum-stability": "stable",
  "require": {},
  "require-dev": {
    "phpunit/phpunit": "^12.5",
    "phpbench/phpbench": "^1.4"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\Polars\\": "tests/",
      "PolarsPhpBench\\": "benchmarks/"
    }
  },
  "scripts": {
    "stubs:debug": "cd .. && cargo php stubs -o php/polars.stubs.php",
    "build:debug": "cd .. && cargo build",
    "build:release": "cd .. && cargo build --release",
    "test:debug": "php -d extension=../target/debug/libpolars_php.so vendor/bin/phpunit tests",
    "test:release": "php -d extension=../target/release/libpolars_php.so vendor/bin/phpunit tests",
    "all:debug": [
      "@build:debug",
      "@stubs:debug",
      "@test:debug"
    ],
    "all:release": [
      "@build:release",
      "@test:release"
    ],
    "bench": "vendor/bin/phpbench run --config=benchmarks/phpbench.json --report=default",
    "bench:polars": "vendor/bin/phpbench run --config=benchmarks/phpbench.json --filter=Polars --report=default",
    "bench:purephp": "vendor/bin/phpbench run --config=benchmarks/phpbench.json --filter=PurePhp --report=default",
    "bench:compare": "php benchmarks/compare-report.php"
  },
  "config": {
    "process-timeout": 900
  }
}
